# LLM Backend Configuration
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
GPT4ALL_BASE_URL=http://localhost:4891/v1
DEFAULT_MODEL=qwen2.5:3b

# Embedding Configuration
EMBEDDING_BACKEND=ollama
EMBEDDING_MODEL=nomic-embed-text
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Fine-tuning Configuration
FINETUNE_BACKEND=auto
HF_BASE_MODEL=Qwen/Qwen2.5-3B-Instruct
FINETUNE_QA_MODEL=qwen2.5-coder:3b
FINETUNE_QA_PAIRS_PER_CHUNK=1
FINETUNE_BATCH_SIZE=8
FINETUNE_CHUNK_TIMEOUT=15

# Ollama Parallelism (for CPU-only and multi-request handling)
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1

# Data Paths
CHROMA_PATH=./data/chromadb
UPLOAD_PATH=./data/uploads
FINETUNED_PATH=./data/finetuned

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# OCR Configuration
TESSERACT_CMD=/usr/bin/tesseract
